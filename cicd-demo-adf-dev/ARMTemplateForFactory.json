				"typeProperties": {
					"url": "[parameters('ls_cicddemodl_access_keys_properties_typeProperties_url')]",
					"accountKey": {
						"type": "AzureKeyVaultSecret",
						"store": {
							"referenceName": "ls_ kv_dev_cicd_demo",
							"type": "LinkedServiceReference"
