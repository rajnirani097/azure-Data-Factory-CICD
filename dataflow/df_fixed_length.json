{
	"name": "df_fixed_length",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_error_rows_data_source",
						"type": "DatasetReference"
					},
					"name": "ReadingFile"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_move_file_target",
						"type": "DatasetReference"
					},
					"name": "sinkDerivedColumn"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          saleDate as string,",
				"          salesItem as string,",
				"          country as string,",
				"          quantity as string,",
				"          fileName as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> ReadingFile",
				"ReadingFile derive(country_code = substring(country, 0, 2)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkDerivedColumn"
			]
		}
	}
}